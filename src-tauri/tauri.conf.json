{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "星灵",
  "version": "0.1.0",
  "identifier": "com.xingling.game",
  "build": {
    "frontendDist": "../xingling-game/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../xingling-game",
    "beforeBuildCommand": "npm run build --prefix ../xingling-game"
  },
  "app": {
    "windows": [
      {
        "title": "星灵",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
